---
import Layout from "../layouts/Layout.astro";
import Menu from "../components/Menu";

import { fetchMenuData } from "../lib/loyverse";
const menuData = await fetchMenuData();
---

<Layout>
	<main class="min-h-screen relative flex flex-col bg-stone-50 pt-5 sm:pt-6">
		{/* Top Decorative Frame SVG */}
		<div
			class="absolute top-0 left-0 w-full h-5 sm:h-6 bg-[url('/frame.svg')] bg-repeat-x bg-[length:auto_100%] z-[60] opacity-90 pointer-events-none mix-blend-multiply drop-shadow-sm"
		>
		</div>

		{/* Hero Section */}
		<div class="relative h-[40vh] min-h-[400px] w-full">
			<div class="absolute inset-0 bg-transparent overflow-hidden">
				<div
					class="absolute inset-0 bg-[url('/Tibetan-cuisine.jpg')] bg-cover bg-center bg-no-repeat bg-fixed opacity-70"
				>
				</div>
				<div
					class="absolute inset-0 bg-gradient-to-b from-stone-50/80 via-stone-50/60 to-stone-50 pointer-events-none"
				>
				</div>
			</div>

			<div
				class="relative z-10 h-full flex flex-col items-center justify-center text-center p-3 pt-6 sm:pt-12"
			>
				{/* Natural Floating Logo */}
				<div
					class="relative flex items-center justify-center group mb-6 hover:scale-105 transition-transform duration-700 w-28 h-28 md:w-36 md:h-36 lg:w-44 lg:h-44"
				>
					<img
						src="/nomade-logo-final-svg.svg"
						alt="Nomade Logo"
						class="w-full h-full object-contain relative z-10 drop-shadow-sm"
					/>
				</div>
				<h1
					class="text-4xl md:text-5xl font-bold text-gray-900 mb-2 tracking-tight drop-shadow-sm"
				>
					<span class="text-amber-700">Nomade</span>
					<span class="text-emerald-600">- Cuisine Tibétaine</span>
				</h1>
				<p
					class="text-lg md:text-xl text-stone-600 font-medium tracking-wide max-w-2xl"
				>
					Authentic Flavors of Tibetan Nomad
				</p>
			</div>
		</div>

		{/* Menu Section natively handles its own split background */}
		<div class="relative z-20">
			<Menu client:load initialData={menuData} />
		</div>

		{/* Footer in Matcha */}
		<footer
			class="relative pt-16 pb-12 text-center text-emerald-100/60 bg-emerald-900 text-sm"
		>
			{/* Decorative Top Frame (White mask) */}
			<div
				class="absolute top-0 left-0 w-full h-5 sm:h-6 bg-white/40 pointer-events-none"
				style="-webkit-mask-image: url('/frame.svg'); mask-image: url('/frame.svg'); -webkit-mask-size: auto 100%; mask-size: auto 100%; -webkit-mask-repeat: repeat-x; mask-repeat: repeat-x;"
			>
			</div>

			<p>
				&copy; {new Date().getFullYear()} Nomade Tibetan Cuisine. All rights
				reserved.
			</p>
		</footer>
	</main>
</Layout>
