---
import Layout from "../layouts/Layout.astro";
import Menu from "../components/Menu";

// In the future, this is where you will fetch data from your Headless CMS
// e.g., const menuData = await sanityClient.fetch('*[_type == "category"]')
import { menuData } from "../data/menu";
---

<Layout>
	<main class="min-h-screen bg-gray-950">
		{/* Hero Section */}
		<div class="relative h-[40vh] min-h-[400px] w-full">
			<div class="absolute inset-0 bg-transparent overflow-hidden">
				<img
					src="Tibetan-cuisine.jpg"
					alt="Restaurant Hero"
					class="w-full h-full object-cover opacity-60"
				/>
				<div
					class="absolute inset-0 bg-gradient-to-b from-gray-9`50/80 via-gray-950/40 to-gray-950 pointer-events-none"
				>
				</div>
			</div>

			<div
				class="relative z-10 h-full flex flex-col items-center justify-center text-center px-4"
			>
				<h1
					class="text-5xl md:text-7xl font-bold text-white mb-4 tracking-tight drop-shadow-lg"
				>
					<span class="text-amber-500">Nomade</span> - cuisine tibétaine
				</h1>
				<p
					class="text-xl md:text-2xl text-gray-300 font-light tracking-wide max-w-2xl"
				>
					Authentic Flavors of Tibetan Nomad
				</p>
			</div>
		</div>

		{/* Menu Section */}
		<div class="relative z-20 -mt-20">
			<div
				class="absolute inset-0 bg-[url('/tibetan-pattern.avif')] bg-fixed bg-[length:200px] bg-repeat opacity-4 pointer-events-none -z-10"
			>
			</div>
			<Menu client:load initialData={menuData} />
		</div>

		{/* Footer */}
		<footer
			class="py-12 text-center text-gray-500 text-sm border-t border-gray-900 mt-20 bg-fixed"
		>
			<p>
				&copy; {new Date().getFullYear()} Nomade Tibetan Cuisine. All rights
				reserved.
			</p>
		</footer>
	</main>
</Layout>
